{
  "name": "@ellyseum/claude-telepty",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive PTY terminal sessions over MCP",
  "main": "dist/mcp-server.js",
  "bin": {
    "claude-telepty": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
